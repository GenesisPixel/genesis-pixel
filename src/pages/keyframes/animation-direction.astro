---
import CourseLayout from '../../layouts/CourseLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const htmlCode = `<div class="direction-demo">
  <div class="direction-row">
    <span class="label">normal (0% → 100%)</span>
    <div class="track"><div class="dot dir-normal"></div></div>
  </div>
  <div class="direction-row">
    <span class="label">reverse (100% → 0%)</span>
    <div class="track"><div class="dot dir-reverse"></div></div>
  </div>
  <div class="direction-row">
    <span class="label">alternate (0% → 100% → 0%)</span>
    <div class="track"><div class="dot dir-alternate"></div></div>
  </div>
  <div class="direction-row">
    <span class="label">alternate-reverse (100% → 0% → 100%)</span>
    <div class="track"><div class="dot dir-alternate-reverse"></div></div>
  </div>
</div>`;

const cssCode = `@keyframes moveRight {
  0% { transform: translateX(0); }
  100% { transform: translateX(calc(100% - 16px)); }
}

.direction-demo {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
}

.direction-row {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.label {
  font-size: 0.75rem;
  color: var(--dm-light-300);
}

.track {
  width: 100%;
  height: 20px;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 9999px;
  padding: 2px;
}

.dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background-color: var(--dm-purple, #a855f7);
  animation: moveRight 2s infinite ease-in-out;
}

.dir-normal {
  animation-direction: normal;
}

.dir-reverse {
  animation-direction: reverse;
  background-color: var(--dm-blue, #3b82f6);
}

.dir-alternate {
  animation-direction: alternate;
  background-color: var(--dm-green, #22c55e);
}

.dir-alternate-reverse {
  animation-direction: alternate-reverse;
  background-color: var(--dm-yellow, #eab308);
}`;

const practiceSteps = [
  { number: 1, text: 'Prueba la dirección "alternate" en un elemento deslizante para evitar saltos bruscos', color: 'dm-purple', rotate: '2deg' },
  { number: 2, text: 'Compara "alternate-reverse" y observa cómo inicia desde el estado final hacia atrás', color: 'dm-green', rotate: '-3deg' },
  { number: 3, text: 'Usa "reverse" para invertir una animación existente sin modificar el código de @keyframes', color: 'app-color-yellow400', rotate: '5deg' },
];
---

<CourseLayout
  title="Animation Direction - Genesis Pixel"
  currentLesson="/keyframes/animation-direction"
  prevLesson={{ title: 'Animation Iteration Count', href: '/keyframes/animation-iteration-count' }}
  nextLesson={{ title: 'Animation Fill Mode', href: '/keyframes/animation-fill-mode' }}
>
  <ChapterHeader
    chapterNumber="01"
    chapterLabel="Capítulo 1 · Lección 11"
    title="Animation Direction"
    readingTime={6}
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>¿Qué es animation-direction?</h3>
    <p>
      La propiedad <code>animation-direction</code> define el sentido de reproducción de la animación a lo largo de su línea de tiempo (si avanza hacia adelante, en reversa o si alterna el sentido en cada ciclo).
    </p>

    <h3>Los cuatro sentidos de reproducción</h3>
    <ul class="space-y-3 mt-4 mb-8 list-none pl-0">
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>normal:</strong> (Valor por defecto) La animación se reproduce en sentido cronológico normal (0% → 100%). Al terminar cada ciclo, se reinicia instantáneamente en el 0%.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>reverse:</strong> La animación se reproduce hacia atrás (100% → 0%). Las funciones de tiempo (easing) también se invierten.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>alternate:</strong> La animación alterna el sentido en cada repetición. Los ciclos impares (1, 3, 5...) van hacia adelante (0% → 100%), mientras que los pares (2, 4, 6...) van en reversa (100% → 0%). Es ideal para lograr un vaivén continuo.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>alternate-reverse:</strong> Igual que alternate, pero invertido: los ciclos impares se reproducen en reversa (100% → 0%) y los pares hacia adelante (0% → 100%).</span>
      </li>
    </ul>

    <h3>Evitando los saltos visuales en loops</h3>
    <p>
      En loops infinitos (como péndulos, latidos, o rebotes), el uso de <code>alternate</code> es fundamental. Si una pelota sube del 0% al 100%, con <code>normal</code> saltará bruscamente al suelo al iniciar el siguiente ciclo. Usando <code>alternate</code>, la pelota bajará de forma natural, creando una transición perfectamente fluida y profesional.
    </p>
  </article>

  <div class="my-8 not-prose">
    <ConsejoProfesional tip="Ten en cuenta que alternate solo funciona cuando animation-iteration-count es mayor a 1 o infinite. Si es 1, solo se reproducirá la primera mitad (hacia adelante) y terminará." />
  </div>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    Ejemplo práctico
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="direction-demo"
      tabs={[
        { id: 'html', label: 'HTML', code: htmlCode },
        { id: 'css', label: 'CSS', code: cssCode },
      ]}
    />
    <ResultPreview description="Compara el comportamiento del recorrido: el verde (alternate) y el amarillo (alternate-reverse) van y vuelven suavemente, mientras que el morado (normal) y el azul (reverse) saltan bruscamente al completarse.">
      <div class="flex items-center justify-center h-full w-full px-4">
        <div class="direction-demo">
          <div class="direction-row">
            <span class="label" style="font-size: 0.75rem; color: var(--dm-light-300);">normal (0% → 100%)</span>
            <div class="track"><div class="dot dir-normal"></div></div>
          </div>
          <div class="direction-row">
            <span class="label" style="font-size: 0.75rem; color: var(--dm-light-300);">reverse (100% → 0%)</span>
            <div class="track"><div class="dot dir-reverse"></div></div>
          </div>
          <div class="direction-row">
            <span class="label" style="font-size: 0.75rem; color: var(--dm-light-300);">alternate (0% → 100% → 0%)</span>
            <div class="track"><div class="dot dir-alternate"></div></div>
          </div>
          <div class="direction-row">
            <span class="label" style="font-size: 0.75rem; color: var(--dm-light-300);">alternate-reverse (100% → 0% → 100%)</span>
            <div class="track"><div class="dot dir-alternate-reverse"></div></div>
          </div>
        </div>
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <ErroresComunesV3 errors={[
      { label: 'Usar "alternate" sin repeticiones', description: 'Declarar alternate con iteration-count: 1 no mostrará el regreso visual de la animación.' },
      { label: 'Invertir curvas complejas incorrectamente', description: 'El navegador invierte el comportamiento matemático del easing en reverse. Revisa que tu cubic-bezier funcione bien en reversa.' },
    ]} />

    <PracticeCards
      title="Practica lo Aprendido"
      description="Cambia la propiedad animation-direction en el código para ver cómo reaccionan las distintas esferas."
      steps={practiceSteps}
    />
  </div>
</CourseLayout>

<style>
  @keyframes moveRight {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(100% - 16px)); }
  }

  .direction-demo {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .direction-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .track {
    width: 100%;
    height: 20px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 9999px;
    padding: 2px;
  }

  .dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--dm-purple, #a855f7);
    animation: moveRight 2s infinite ease-in-out;
  }

  .dir-normal {
    animation-direction: normal;
  }

  .dir-reverse {
    animation-direction: reverse;
    background-color: var(--dm-blue, #3b82f6);
  }

  .dir-alternate {
    animation-direction: alternate;
    background-color: var(--dm-green, #22c55e);
  }

  .dir-alternate-reverse {
    animation-direction: alternate-reverse;
    background-color: var(--dm-yellow, #eab308);
  }
</style>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';
  document.addEventListener('astro:page-load', () => initCodeInteractions());
</script>
