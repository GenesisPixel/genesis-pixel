---
import CourseLayout from '../layouts/CourseLayout.astro';

const stats = [
  { label: 'Capítulos', value: '3' },
  { label: 'Lecciones', value: '29' },
  { label: 'Nivel', value: 'Principiante → Avanzado' },
  { label: 'Tiempo Estimado', value: '12 horas' },
];

const resources = [
  { name: 'MDN Web Docs', description: 'Documentación oficial de CSS Animations.', url: 'https://developer.mozilla.org/en-US/docs/Web/CSS/CSS_Animations', icon: '📚' },
  { name: 'CSS Tricks', description: 'Guías y tutoriales prácticos.', url: 'https://css-tricks.com', icon: '🎨' },
  { name: 'W3Schools', description: 'Referencias y ejemplos interactivos.', url: 'https://www.w3schools.com/css/css_animations.asp', icon: '🎓' },
  { name: 'Frontend Mentor', description: 'Proyectos prácticos para mejorar.', url: 'https://www.frontendmentor.io', icon: '💼' },
];

const faq = [
  {
    question: '¿Necesito conocimientos previos de CSS?',
    answer: 'Sí, es recomendable tener dominio básico de CSS, incluyendo selectores, propiedades y modelo de caja. Este curso se enfoca específicamente en animaciones.',
  },
  {
    question: '¿Puedo seguir el curso a mi ritmo?',
    answer: 'Absolutamente. El curso está diseñado para que avances a tu propio ritmo. Cada lección es independiente y puedes volver a cualquier momento.',
  },
  {
    question: '¿Las animaciones funcionan en todos los navegadores?',
    answer: 'Las propiedades básicas de CSS animations y transitions tienen soporte amplio. Las transformaciones 3D pueden requerir prefijos vendor en navegadores más antiguos.',
  },
  {
    question: '¿Puedo usar estas técnicas en proyectos profesionales?',
    answer: 'Sí, todas las técnicas enseñadas son aplicables directamente en proyectos reales. El curso incluye mejores prácticas para producción.',
  },
];
---

<CourseLayout
  title="CSS Animation - GenesisPixel"
  currentLesson="/css-animation"
  nextLesson={{ title: '¿Qué son los Keyframes?', href: '/css-animation/keyframes/que-son' }}
>
  <div class="mb-8">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-[var(--dm-light-200)]">
      <span class="h-2 w-2 rounded-full bg-[var(--dm-green)] animate-pulse"></span>
      Curso Actualizado 2024
    </div>
    
    <h1 class="font-afronaut text-4xl font-light leading-tight tracking-tight text-[var(--color-text)] sm:text-5xl">
      CSS Animations
    </h1>
    
    <p class="mt-4 text-lg text-[var(--dm-light-200)]">
      Domina el arte de crear animaciones web profesionales. Desde keyframes básicos hasta transformaciones 3D complejas.
    </p>
    
    <p class="mt-4 text-[var(--dm-light-300)]">
      Aprende a dar vida a tus interfaces con animaciones fluidas, performantes y compatibles con todos los navegadores modernos. Este curso te llevará desde los conceptos fundamentales hasta técnicas avanzadas utilizadas en las mejores aplicaciones web del mundo.
    </p>

    <div class="mt-8 flex flex-col gap-4 sm:flex-row">
      <a
        href="/css-animation/keyframes/que-son"
        class="inline-flex items-center justify-center gap-2 rounded-[var(--radius-base)] bg-[var(--color-text)] px-6 py-3 text-sm font-semibold text-[var(--dm-dark-500)] transition-all hover:opacity-90"
      >
        Comenzar Curso
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="#recursos"
        class="inline-flex items-center justify-center gap-2 rounded-[var(--radius-base)] border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-[var(--color-text)] transition-all hover:bg-white/10"
      >
        Explorar Recursos
      </a>
    </div>
  </div>

  <div class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
    {stats.map((stat) => (
      <div class="rounded-xl border border-white/5 bg-white/[0.02] p-4">
        <div class="text-2xl font-light text-[var(--color-text)]">{stat.value}</div>
        <div class="mt-1 text-sm text-[var(--dm-light-300)]">{stat.label}</div>
      </div>
    ))}
  </div>

  <div class="mb-8 rounded-xl border border-white/5 bg-white/[0.02] p-6">
    <h2 class="mb-4 font-afronaut text-xl font-light text-[var(--color-text)]">¿Qué aprenderás?</h2>
    <ul class="grid gap-3 sm:grid-cols-2 text-sm text-[var(--dm-light-200)]">
      <li class="flex items-start gap-2">
        <svg class="mt-0.5 h-4 w-4 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Crear animaciones fluidas con @keyframes
      </li>
      <li class="flex items-start gap-2">
        <svg class="mt-0.5 h-4 w-4 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Transformar elementos en 2D y 3D
      </li>
      <li class="flex items-start gap-2">
        <svg class="mt-0.5 h-4 w-4 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Controlar transiciones suaves
      </li>
      <li class="flex items-start gap-2">
        <svg class="mt-0.5 h-4 w-4 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Optimizar rendimiento de animaciones
      </li>
      <li class="flex items-start gap-2">
        <svg class="mt-0.5 h-4 w-4 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Timing functions y easing
      </li>
      <li class="flex items-start gap-2">
        <svg class="mt-0.5 h-4 w-4 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Mejores prácticas para producción
      </li>
    </ul>
  </div>

  <div id="faq" class="mb-8">
    <h2 class="mb-4 font-afronaut text-xl font-light text-[var(--color-text)]">Preguntas Frecuentes</h2>
    <div class="space-y-3">
      {faq.map((item) => (
        <details class="group rounded-xl border border-white/5 bg-white/[0.02]">
          <summary class="flex cursor-pointer items-center justify-between p-4 text-[var(--color-text)] hover:bg-white/[0.02] rounded-xl">
            <span class="font-medium text-sm">{item.question}</span>
            <svg class="h-4 w-4 text-[var(--dm-light-300)] transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 text-sm text-[var(--dm-light-300)]">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>

  <div id="recursos">
    <h2 class="mb-4 font-afronaut text-xl font-light text-[var(--color-text)]">Recursos Recomendados</h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {resources.map((resource) => (
        <a
          href={resource.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-3 rounded-xl border border-white/5 bg-white/[0.02] p-4 transition-all hover:border-white/10 hover:bg-white/[0.04]"
        >
          <span class="text-xl">{resource.icon}</span>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-text)] group-hover:text-white">{resource.name}</h3>
            <p class="mt-1 text-xs text-[var(--dm-light-300)]">{resource.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</CourseLayout>
