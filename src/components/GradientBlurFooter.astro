---
---
<div class="gradient-blur-footer-container">
  <div class="content--canvas gradient-blur-footer-wrapper"></div>
  <div class="gradient-footer-overlay"></div>
</div>

<script is:inline src="/js/noise.min.js"></script>
<script is:inline src="/js/util.js"></script>
<script is:inline src="/js/shift.js"></script>

<style>
  .gradient-blur-footer-container {
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .gradient-blur-footer-wrapper {
    width: 100%;
    height: 100%;
  }

  .gradient-footer-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 0%, hsla(160, 23%, 18%, 0.3) 50%, var(--color-bg) 100%);
    z-index: 5;
  }

  :global(.content--canvas canvas) {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    z-index: 1;
  }
</style>
