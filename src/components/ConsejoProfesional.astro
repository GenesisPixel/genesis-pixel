---
interface Props {
  tip: string;
}

const { tip } = Astro.props;
---

<div class="border-l-[3px] border-[var(--color-text)] bg-[var(--dm-green-bg)] p-6">
  <h3 class="mb-4 font-medium text-[var(--color-text)] !text-sm !mt-0">
    Consejo profesional
  </h3>
  <p class="text-soft-white !text-sm !m-0 !leading-relaxed">
    <Fragment set:html={tip} />
  </p>
</div>
