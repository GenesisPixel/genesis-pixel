---
---
<div class="gradient-blur-container" id="gradient-container">
  <div class="content--canvas gradient-blur-wrapper"></div>
  <div class="gradient-overlay"></div>
</div>

<script is:inline src="/js/noise.min.js"></script>
<script is:inline src="/js/util.js"></script>
<script is:inline src="/js/shift.js"></script>

<script is:inline>
  document.addEventListener('scroll', () => {
    const container = document.getElementById('gradient-container');
    if (!container) return;
    
    // The gradient height is 80vh. We want to leave 10vh visible at the top.
    // So it can scroll up by a maximum of 70vh.
    const maxScroll = window.innerHeight * 0.7;
    const scrollY = window.scrollY;
    
    const y = Math.min(scrollY, maxScroll);
    container.style.transform = `translateY(-${y}px)`;
  }, { passive: true });
</script>

<style>
  .gradient-blur-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80vh;
    z-index: -10;
    pointer-events: none;
    overflow: hidden;
    will-change: transform;
  }

  .gradient-blur-wrapper {
    width: 100%;
    height: 100%;
  }

  .gradient-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 5%, var(--color-bg) 95%);
    z-index: 5;
  }

  :global(.content--canvas canvas) {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    z-index: 1;
  }
</style>
