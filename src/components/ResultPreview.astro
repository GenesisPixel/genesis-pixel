---
interface Props {
  description?: string;
}

const { description } = Astro.props;
---

<div class="overflow-hidden rounded-none shadow-lg" style="background-color: hsla(158, 23%, 10%, 1); flex: 1; min-width: 0;">
  <!-- Console Header -->
  <div class="flex items-center gap-4 border-b px-4 py-3" style="border-color: rgba(255,255,255,0.06); background-color: hsla(158, 23%, 8%, 1);">
    <div class="flex gap-1.5">
      <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-red)]"></div>
      <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-yellow)]"></div>
      <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-green)]"></div>
    </div>
    <div class="flex items-center gap-1 font-mono text-[11px]">
      <span class="text-[var(--dm-green)] font-bold">></span>
      <span class="animate-blink text-[var(--dm-green)] font-bold">_</span>
    </div>
  </div>
  
  <!-- Result Content -->
  <div class="flex flex-col overflow-y-auto" style="height: 400px;">
    <div class="flex flex-1 items-center justify-center p-8">
      <slot />
    </div>
    {description && (
      <div class="border-t px-6 py-4" style="border-color: rgba(255,255,255,0.06);">
        <p class="text-xs text-[var(--dm-light-300)] leading-relaxed" style="opacity: 0.7 !important;">
          {description}
        </p>
      </div>
    )}
  </div>
</div>
