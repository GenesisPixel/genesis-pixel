---
import BentoCard from './BentoCard.astro';

const { variant = 'default' } = Astro.props;
const isEqual = variant === 'equal';
---

<section class="mx-auto w-full max-w-[1200px] px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
    
    <!-- Card 1: Keyframes -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-4']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #9FA6FF; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Principiante</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src="/svg/stars-in-orbit.svg" alt="Icon" class="absolute -top-[46px] left-4 w-[112px] h-[112px] opacity-0 translate-y-[28px] transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:opacity-100 group-hover:translate-y-0" />
      </div>
      <BentoCard 
        href="/keyframes/que-son"
        class="bg-[#cd94eb] px-8"
        subtitle="Capítulo 1"
        title="Keyframes"
        textColor="text-[#5c3e73]"
        imageAlt="Keyframes Mockup"
      />
    </div>

    <!-- Card 2: Transform -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-8']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #57B0FB; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Intermedio</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src="/svg/pencil.svg" alt="Icon" class="absolute -top-[46px] left-8 w-[112px] h-[112px] opacity-0 translate-y-[28px] transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:opacity-100 group-hover:translate-y-0" />
        <img src="/svg/garabato.svg" alt="Icon" class="absolute -top-[6px] left-1/3 w-[112px] h-[112px] opacity-0 translate-y-[28px] transition-all duration-500 delay-75 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:opacity-100 group-hover:translate-y-0" />
      </div>
      <BentoCard 
        href="/transform/que-es"
        class="bg-[#aee2cd] px-10"
        subtitle="Capítulo 2"
        title="Transform"
        textColor="text-[#3a6355]"
        imageAlt="Transform Mockup"
      />
    </div>

    <!-- Card 3: Transitions -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-8']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #FC5D7D; color: white; font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Avanzado</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src="/svg/frame.svg" alt="Icon" class="absolute -top-[46px] left-8 w-[112px] h-[112px] opacity-0 translate-y-[28px] transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:opacity-100 group-hover:translate-y-0" />
        <img src="/svg/stars.svg" alt="Icon" class="absolute -top-[14px] left-1/3 w-[112px] h-[112px] opacity-0 translate-y-[28px] transition-all duration-500 delay-75 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:opacity-100 group-hover:translate-y-0" />
      </div>
      <BentoCard 
        href="/transitions/que-son"
        class="bg-[#e3bc9b] px-10"
        subtitle="Capítulo 3"
        title="Transitions"
        textColor="text-[#5e4b3c]"
        imageAlt="Transitions Mockup"
      />
    </div>

    <!-- Card 4: Interacciones -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-4']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #FDD88E; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Experto</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src="/svg/mobile-phone.svg" alt="Icon" class="absolute -top-[46px] left-4 w-[112px] h-[112px] opacity-0 translate-y-[28px] transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:opacity-100 group-hover:translate-y-0" />
      </div>
      <BentoCard 
        href="/interactions/que-son"
        class="bg-[#bce1fb] px-8"
        subtitle="Capítulo 4"
        title="Interacciones"
        textColor="text-[#3e5366]"
        imageAlt="Interacciones Mockup"
      />
    </div>

  </div>

</section>

