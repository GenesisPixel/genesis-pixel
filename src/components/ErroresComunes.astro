---
interface Props {
  errors: { label: string; description: string }[];
}

const { errors } = Astro.props;
---

<div class="py-6 overflow-hidden">
  <h3 class="mb-6 font-medium text-[var(--color-text)] text-lg">
    Errores Comunes
  </h3>
  <div class="flex flex-col gap-4">
    {errors.slice(0, 4).map((error, index) => {
      const widths = ['380px', '320px', '400px', '300px'];
      return (
        <div class="block w-full">
          <div
            style={`width: ${widths[index]}; transform: translateX(${index * 20}px);`}
            class="rounded-[20px] bg-[var(--color-text)] px-4 py-3 text-[var(--color-bg)] shadow-md transition-transform hover:-translate-y-1"
          >
            <p class="m-0 text-[12px] leading-snug">
              <span class="mr-1 font-bold text-[13px]">{error.label}:</span>
              {error.description}
            </p>
          </div>
        </div>
      );
    })}
  </div>
</div>
