---
interface Props {
  errors: { label: string; description: string }[];
}

const { errors } = Astro.props;
---

<div class="p-6">
  <h3 class="mb-4 font-medium text-[var(--color-text)]">
    Errores Comunes
  </h3>
  <ul class="space-y-2 text-sm text-soft-white">
    {errors.map((error) => (
      <li class="flex items-start gap-2">
        <span class="mt-1 text-yellow-500">&bull;</span>
        <span><strong>{error.label}:</strong> {error.description}</span>
      </li>
    ))}
  </ul>
</div>
