---
interface Props {
  href?: string;
  class?: string;
  textColor: string;
  subtitle: string;
  title: string;
  imageSrc?: string;
  imageAlt?: string;
  badge?: string;
  badgeColor?: string;
}

const {
  href = '#',
  class: className = '',
  textColor,
  subtitle,
  title,
  imageSrc = '/img/card.png',
  imageAlt = 'Card Mockup',
  badge = '',
  badgeColor = '#9FA6FF'
} = Astro.props;
---

<a href={href} class:list={['relative flex flex-col justify-between overflow-hidden rounded-[50px] pt-10 pb-0 h-full w-full', className]}>
  {badge && (
    <span style={`position: absolute; top: 12px; right: 12px; background: ${badgeColor}; color: var(--color-bg); font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;`}>{badge}</span>
  )}
  <!-- Text -->
  <div class="relative z-10 flex flex-col items-end text-right mb-8">
    <span class:list={['text-[10px] font-bold tracking-[0.2em] uppercase mb-1', textColor]}>{subtitle}</span>
    <h2 class:list={['text-4xl font-bold tracking-tight font-[family:var(--font-google-sans)]', textColor]}>{title}</h2>
  </div>
  
  <!-- Mockup UI -->
  <picture class="relative w-[120%] h-[300px] translate-x-[15px] translate-y-[15px] transition-transform duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:translate-y-[35px]">
    <img src={imageSrc} alt={imageAlt} class="w-[100%] h-[100%] rounded-t-[18px] mt-auto object-cover object-top object-left" />
  </picture>
</a>
